{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wilson Term",
  "version": "0.11.0",
  "identifier": "com.wilson.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Wilson Term",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png"
    ],
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://gitee.com/zhouws-chn/wilson-term/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
